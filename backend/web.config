<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <!-- Khai báo sử dụng HttpPlatformHandler để chạy Python/FastAPI -->
      <add name="httpPlatformHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" requireAccess="Script" />
    </handlers>
    
    <!-- Cấu hình chạy Uvicorn bằng Python trên máy tính của bạn -->
    <httpPlatform processPath="C:\Users\Admin\AppData\Local\Programs\Python\Python310\python.exe"
                  arguments="-m uvicorn main_vietocr:app --port %HTTP_PLATFORM_PORT%"
                  stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\uvicorn.log"
                  startupTimeLimit="120"
                  processesPerApplication="1">
      <environmentVariables>
        <!-- Tắt thời gian chờ đệm console để xem log realtime -->
        <environmentVariable name="PYTHONUNBUFFERED" value="1" />
        <!-- Đảm bảo PaddleOCR tải models ở đúng thư mục user của Admin -->
        <environmentVariable name="USERPROFILE" value="C:\Users\Admin" />
        <environmentVariable name="HOME" value="C:\Users\Admin" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>
